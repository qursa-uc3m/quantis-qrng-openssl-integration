# Minimal example configuration. Merge these sections into the configuration
# used by the OpenSSL installation that will load the provider.
openssl_conf = openssl_init
config_diagnostics = 1

[openssl_init]
providers = provider_sect

[provider_sect]
# Explicitly keep the default provider active when another provider is enabled.
default = default_sect
quantis = quantis_sect

[default_sect]
activate = 1

[quantis_sect]
activate = 1
module = /opt/quantis/providers/lib/libcustom_qrng_provider.so
